void reviver_gousma(int furia[][2], int status[][2], int jogador, int gousma_viva, int gousma_morta) {
    int metade = furia[jogador][gousma_viva] / 2;
    
    if (metade < 1) metade = 1;  // garante minimo de 1
    
    furia[jogador][gousma_morta] = metade;
    furia[jogador][gousma_viva]  = metade;
    status[jogador][gousma_morta] = 0;
