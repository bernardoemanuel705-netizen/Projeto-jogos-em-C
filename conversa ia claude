Em C, você usa a função system() para limpar o console:

c
// Windows
system("cls");

// Linux / Mac
system("clear");
Como seu programa roda no Windows (pelo contexto), aplica assim no loop de validação:

c
do {
    scanf("%d", &esc);
    while (getchar() != '\n'); // limpa buffer

    if (esc < 1 || esc > 4) {
        system("cls");          // limpa o console
        printf("JOGOS BACANAS\n");
        printf("1: Perguntas e Respostas\n");
        printf("2: Cobra na Caixa!\n");
        printf("3: Gousmas War\n");
        printf("4: Sair\n");
        printf("Opcao invalida! Tente novamente: \n");
    }

} while (esc < 1 || esc > 4);
O menu é reimpresso depois do cls porque limpar o console apaga tudo — sem reimprimir, o usuário ficaria com a tela vazia sem saber o que digitar.

Se quiser deixar o código mais organizado e sem repetir o printf do menu em dois lugares, pode criar uma função separada:

c
#include <stdio.h>
#include <stdlib.h>
#include <time.h>

void exibir_menu() {
    system("cls");
    printf("JOGOS BACANAS\n");
    printf("1: Perguntas e Respostas\n");
    printf("2: Cobra na Caixa!\n");
    printf("3: Gousmas War\n");
    printf("4: Sair\n");
}

int main()
{
    int esc;
    // ...

    exibir_menu();  // primeira exibição

    do {
        scanf("%d", &esc);
        while (getchar() != '\n');

        if (esc < 1 || esc > 4) {
            exibir_menu();  // reexibe após entrada inválida
            printf("Opcao invalida! Tente novamente: \n");
        }

    } while (esc < 1 || esc > 4);

    // switch...
}
Essa abordagem com função é mais limpa e fácil de manter — se quiser mudar o menu, altera em um só lugar.

