Porém isso gera outro problema — se a fúria da viva for 1, ambas ficariam com 1, o que significa que a viva não perdeu nada. A solução mais justa é:

c
void reviver_gousma(int furia[][2], int status[][2], int jogador, int gousma_viva, int gousma_morta) {
    int metade = furia[jogador][gousma_viva] / 2;

    furia[jogador][gousma_morta] = metade < 1 ? 1 : metade;  // morta recebe minimo 1
    furia[jogador][gousma_viva]  = furia[jogador][gousma_viva] - furia[jogador][gousma_morta]; // viva perde o que a morta recebeu
    
    if (furia[jogador][gousma_viva] < 1)
        furia[jogador][gousma_viva] = 1;  // viva tambem nao pode ficar com 0

    status[jogador][gousma_morta] = 0;
}
