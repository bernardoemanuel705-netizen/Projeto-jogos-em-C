                printf("\n==============================\n");
                printf("  Jogador %d VENCEU O JOGO!\n", vencedor);
                printf("==============================\n\n");
                printf("Pressione ENTER para voltar ao menu...");
                pausar();
                break;
            }

            case 4:
                limpar_tela();
                printf("Saindo... Ate logo!\n");
                break;
        }

    } while (esc != 4);

