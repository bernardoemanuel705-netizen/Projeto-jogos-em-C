                                    status[turno][alvo_contra] = 1;
                                    printf("\nGousma %d do Jogador %d MORREU!\n", alvo_contra + 1, turno + 1);
                                }
                            }
                        }
                    }

                    printf("\nPressione ENTER para continuar...");
                    pausar();
                    turno = 1 - turno;
